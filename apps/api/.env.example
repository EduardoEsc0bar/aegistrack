AEGISTRACK_API_ENV=development
AEGISTRACK_API_DATABASE_URL=postgresql+psycopg://aegistrack:aegistrack@localhost:5432/aegistrack
AEGISTRACK_API_REDIS_URL=redis://localhost:6379/0
AEGISTRACK_API_ALLOWED_ORIGINS=http://localhost:3000
